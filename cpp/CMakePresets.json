{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-release",
      "displayName": "Windows MSVC Release",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/../build/cpp-windows",
      "cacheVariables": {
        "BUILD_TESTING": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/../build/cpp-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "arm64-release",
      "displayName": "Linux ARM64 Cross Compile",
      "inherits": "linux-release",
      "binaryDir": "${sourceDir}/../build/cpp-arm64",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/../tools/cmake/aarch64-linux-gnu.toolchain.cmake",
        "BUILD_TESTING": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "configuration": "Release"
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release"
    },
    {
      "name": "arm64-release",
      "configurePreset": "arm64-release"
    }
  ],
  "testPresets": [
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "configuration": "Release",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release",
      "output": {"outputOnFailure": true}
    }
  ]
}
